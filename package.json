{
  "name": "abyss",
  "version": "1.42.0",
  "description": "Unified visual configuration UI for AI coding agents (Claude Code, Codex, Gemini CLI, and more).",
  "private": true,
  "author": "Fxbixn03",
  "license": "MIT",
  "homepage": "https://github.com/Fxbixn03/Abyss#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fxbixn03/Abyss.git"
  },
  "bugs": {
    "url": "https://github.com/Fxbixn03/Abyss/issues"
  },
  "keywords": [
    "electron",
    "ai",
    "agents",
    "claude-code",
    "codex",
    "gemini-cli",
    "mcp",
    "configuration",
    "developer-tools",
    "desktop-app"
  ],
  "main": "dist-electron/main.js",
  "bin": {
    "abyss": "dist-cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build && pnpm build:cli && electron-builder --config electron-builder.config.cjs",
    "build:dir": "tsc --noEmit -p tsconfig.app.json && vite build && pnpm build:cli && electron-builder --dir --config electron-builder.config.cjs",
    "build:cli": "tsup cli/index.ts --format cjs --out-dir dist-cli --target node20 --clean --minify --tsconfig tsconfig.node.json",
    "cli": "tsx --tsconfig tsconfig.node.json cli/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "test": "tsx --tsconfig tsconfig.node.json --test tests/*.test.ts",
    "format": "prettier --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@uiw/react-codemirror": "^4.25.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "commander": "^15.0.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4",
    "remark-gfm": "^4.0.1",
    "smol-toml": "^1.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.2",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
